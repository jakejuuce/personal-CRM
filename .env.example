# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server-only, never exposed to client

# Anthropic (the matcher / normalizer / intro-draft)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
# Model overrides (optional — sensible defaults in src/lib/llm.ts)
LLM_MODEL_NORMALIZE=claude-haiku-4-5-20251001
LLM_MODEL_MATCH=claude-sonnet-4-6
LLM_MODEL_DRAFT=claude-sonnet-4-6

# Telegram (tag-writer inbound + confirm buttons)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_ALLOWED_CHAT_IDS=123456789   # comma-separated; only these chat IDs may write (F2)
TELEGRAM_WEBHOOK_SECRET=a-random-string   # validates inbound webhook calls

# App
APP_BASE_URL=http://localhost:3000
